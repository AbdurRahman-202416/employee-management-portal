# ============================================================
#  ENVIRONMENT VARIABLES — copy to .env.local and fill in.
#  Leave a value empty to use the safe local default where one exists.
# ============================================================

# Database. Leave EMPTY to run on the built-in seeded demo data (no DB needed).
# When set, the app switches to MongoDB automatically.
MONGODB_URI=

# Secret used to sign login sessions. Generate with: openssl rand -base64 32
# If empty, a development-only fallback is used (NOT for production).
AUTH_SECRET=

# File uploads (employee photos / documents). Optional for the demo.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public site URL (used in links/emails later). Optional for the demo.
NEXT_PUBLIC_APP_URL=
